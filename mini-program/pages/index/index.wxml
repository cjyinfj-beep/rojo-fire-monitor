<view class="container">
  <view wx:if="{{loading}}" class="loading">正在加载设备数据...</view>
  <view wx:elif="{{error}}" class="error">{{error}}
    <view style="margin-top:20rpx;">
      <button class="btn-primary" bindtap="refresh">重试</button>
    </view>
  </view>
  <view wx:elif="{{devices.length === 0}}" class="empty">
    <view>暂无设备数据</view>
    <view style="margin-top:20rpx;">
      <button class="btn-primary" bindtap="refresh">刷新</button>
    </view>
  </view>
  <view wx:if="{{devices.length > 0}}" class="card" style="margin-bottom:20rpx;">
    <view style="display:flex;justify-content:space-between;align-items:center;">
      <view>
        <view style="font-size:28rpx;color:#4caf50;font-weight:bold;">系统状态</view>
        <view style="font-size:24rpx;color:#888;margin-top:6rpx;">{{devices.length}} 个设备在线</view>
      </view>
      <view style="font-size:60rpx;">🟢</view>
    </view>
  </view>
  <block wx:for="{{devices}}" wx:key="id">
    <view class="card">
      <view class="card-title">📡 {{item.id}}</view>
      <view class="card-label">{{item.location}}</view>
      <view style="display:flex;justify-content:space-between;margin-top:20rpx;text-align:center;">
        <view>
          <view class="card-value {{item._tempClass}}">{{item.temperature}}<text class="card-unit">°C</text></view>
          <view class="card-label">温度</view>
        </view>
        <view>
          <view class="card-value {{item._distClass}}">{{item.distance}}<text class="card-unit">cm</text></view>
          <view class="card-label">距离</view>
        </view>
        <view>
          <view class="card-value {{item._colorClass}}">{{item.color_status || '未知'}}</view>
          <view class="card-label">颜色</view>
        </view>
        <view>
          <view class="card-value {{item._statusClass}}">{{item.alarm ? '异常' : '正常'}}</view>
          <view class="card-label">状态</view>
        </view>
      </view>
      <view wx:if="{{item.alarm_reason}}" class="status-warning" style="margin-top:15rpx;font-size:24rpx;background:#3a2810;padding:16rpx;border-radius:8rpx;">⚠️ {{item.alarm_reason}}</view>
    </view>
  </block>
  <view style="text-align:center;padding:40rpx 20rpx;">
    <navigator url="/pages/privacy/privacy" style="color:#666;font-size:24rpx;text-decoration:underline;">隐私政策</navigator>
  </view>
</view>