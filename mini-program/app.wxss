page {
  background-color: #0a0e1a;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #0a0e1a;
}

.card {
  background: #151d2f;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #4caf50;
  margin-bottom: 20rpx;
}

.card-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ffffff;
}

.card-unit {
  font-size: 24rpx;
  color: #888;
  margin-left: 10rpx;
}

.card-label {
  font-size: 26rpx;
  color: #888;
  margin-top: 10rpx;
}

.status-normal {
  color: #4caf50;
}

.status-warning {
  color: #ff9800;
}

.status-danger {
  color: #f44336;
}

.status-yellow {
  color: #ffeb3b;
}

.btn-primary {
  background: #4caf50;
  color: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.input-field {
  background: #1a2340;
  border: 1rpx solid #2a3a5c;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 40rpx;
  color: #888;
  font-size: 28rpx;
}

.empty {
  text-align: center;
  padding: 60rpx;
  color: #666;
  font-size: 28rpx;
}

.error {
  text-align: center;
  padding: 40rpx;
  color: #f44336;
  font-size: 28rpx;
}